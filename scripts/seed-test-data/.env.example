# GitHub — create a PAT at https://github.com/settings/tokens (scopes: repo, read:user)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-username
GITHUB_TEST_REPO=devrecall-test-data

# GitLab — create a PAT at https://gitlab.com/-/user_settings/personal_access_tokens (scopes: api)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_USERNAME=your-username
GITLAB_TEST_PROJECT=devrecall-test-data

# Bitbucket — create app password at https://bitbucket.org/account/settings/app-passwords/ (scopes: repository, pullrequest)
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_TEST_REPO=devrecall-test-data

# Jira — create API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
JIRA_PROJECT_KEY=DRT

# Confluence — shares Atlassian auth with Jira
CONFLUENCE_SPACE_KEY=DRT

# Linear — create API key at https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx
LINEAR_TEAM_KEY=DRT

# Slack — create test app at https://api.slack.com/apps, install to workspace
# Bot scopes: chat:write, channels:manage, channels:join
# User scopes: search:read (for the collector)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_NAME=devrecall-test

# Google Calendar — use a service account or OAuth token
# Easiest: get a short-lived access token via `devrecall auth google`, then copy from ~/.devrecall/tokens/
GOOGLE_CALENDAR_ACCESS_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary

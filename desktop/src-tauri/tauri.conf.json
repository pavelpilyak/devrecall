{
  "$schema": "https://raw.githubusercontent.com/niclas-niclas/tauri-v2-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "DevRecall",
  "version": "0.1.0",
  "identifier": "dev.devrecall.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DevRecall",
        "width": 420,
        "height": 520,
        "resizable": true,
        "visible": false,
        "decorations": true
      }
    ],
    "trayIcon": {
      "id": "devrecall-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "DevRecall"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://releases.devrecall.dev/tauri/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}

{
  "$schema": "https://raw.githubusercontent.com/niclas-niclas/tauri-v2-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "DevRecall",
  "version": "0.1.8",
  "identifier": "dev.devrecall.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DevRecall",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "visible": true,
        "decorations": true
      }
    ]
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/devrecall"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "signingIdentity": "-",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
